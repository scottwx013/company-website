# Vercel 部署配置
# 复制此文件为 .env 并填入实际值

# Vercel Token (从 Vercel Dashboard → Settings → Tokens 获取)
VERCEL_TOKEN=your_vercel_token_here

# Vercel Org ID (从 Vercel Project → Settings → General → Project ID 下方获取)
VERCEL_ORG_ID=your_org_id_here

# Vercel Project ID (从 Vercel Project → Settings → General 获取)
VERCEL_PROJECT_ID=your_project_id_here
